<Window x:Class="WPFAI_LiveChart.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFAI_LiveChart"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="8" Grid.Row="0">
            <Button Content="更新测试数据" Padding="6,3" Margin="0,0,8,0"
                    Command="{Binding UpdateTestDataCommand}" />
            <!-- 新增截图按钮，通过 CommandParameter 传递图表控件 -->
            <Button Content="保存图表截图" Padding="6,3"
                    Command="{Binding SaveChartImageCommand}"
                    CommandParameter="{Binding ElementName=MyChart}" />
        </StackPanel>

        <!-- 添加 x:Name="MyChart" -->
        <lvc:CartesianChart x:Name="MyChart" Grid.Row="1" Series="{Binding SeriesCollection}" LegendLocation="Top" Margin="8">
            <lvc:CartesianChart.AxisX>
                <lvc:Axis Title="X" />
            </lvc:CartesianChart.AxisX>
            <lvc:CartesianChart.AxisY>
                <lvc:Axis Title="Y" />
            </lvc:CartesianChart.AxisY>
        </lvc:CartesianChart>
    </Grid>
</Window>
