<Page x:Class="WpfAIApp.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Page3">
    <ScrollViewer>
        <StackPanel Margin="20">
            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="#222" />
            <TextBlock Text="Adjust application preferences and account options." Margin="0,0,0,12" />

            <Border Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,12" Width="560">
                <StackPanel>
                    <TextBlock Text="Account" FontWeight="Bold" Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Width="120" VerticalAlignment="Center">Display name:</TextBlock>
                        <TextBox Width="320" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Width="120" VerticalAlignment="Center">Email:</TextBlock>
                        <TextBox Width="320" />
                    </StackPanel>

                    <TextBlock Text="Preferences" FontWeight="Bold" Margin="0,12,0,6" />

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Width="120" VerticalAlignment="Center">Theme:</TextBlock>
                        <ComboBox Width="160">
                            <ComboBoxItem>Light</ComboBoxItem>
                            <ComboBoxItem>Dark</ComboBoxItem>
                            <ComboBoxItem>System</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <CheckBox Content="Remember me" Margin="120,0,0,0" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Save" Width="100" />
                        <Button Content="Reset" Width="100" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="12" Width="560">
                <StackPanel>
                    <TextBlock Text="Advanced" FontWeight="Bold" />
                    <TextBlock Text="Logs and debug options (placeholder)" Margin="0,8,0,0" />
                    <Button Content="Export logs" Width="120" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>