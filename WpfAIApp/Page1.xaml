<Page  x:Class="WpfAIApp.Page1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAIApp"
        mc:Ignorable="d"
        Title="Page1" >
    <ScrollViewer>
        <StackPanel Margin="20">
            <TextBlock Text="欢迎访问页面1" FontSize="24" FontWeight="Bold" Foreground="#222" />
            <TextBlock Text="这里是页面1的内容区域，下面展示一些示例卡片。" Margin="0,0,0,12" />

            <WrapPanel ItemHeight="140" ItemWidth="320" Orientation="Horizontal">
                <!-- Card 1 -->
                <Border Background="White" CornerRadius="8" Padding="12" Margin="8" Width="320" Height="140" Effect="{x:Null}">
                    <StackPanel>
                        <TextBlock Text="示例功能 A" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="描述：这是功能 A 的简短说明。" Margin="0,6,0,0" />
                        <Button Content="打开" Width="80" Margin="0,10,0,0" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- Card 2 -->
                <Border Background="White" CornerRadius="8" Padding="12" Margin="8" Width="320" Height="140">
                    <StackPanel>
                        <TextBlock Text="示例功能 B" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="描述：这是功能 B 的简短说明。" Margin="0,6,0,0" />
                        <Button Content="打开" Width="80" Margin="0,10,0,0" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- Card 3 -->
                <Border Background="White" CornerRadius="8" Padding="12" Margin="8" Width="320" Height="140">
                    <StackPanel>
                        <TextBlock Text="示例功能 C" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="描述：这是功能 C 的简短说明。" Margin="0,6,0,0" />
                        <Button Content="打开" Width="80" Margin="0,10,0,0" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
