<Page x:Class="WpfAIApp.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Page2">
    <ScrollViewer>
        <StackPanel Margin="20">
            <TextBlock Text="Overview" FontSize="24" FontWeight="Bold" Foreground="#222" />
            <TextBlock Text="This shows statistics and recent activity." Margin="0,0,0,12" />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <!-- 左侧：统计卡片/图表占位 -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Key Metrics" FontSize="16" FontWeight="Bold" />
                        <WrapPanel Margin="0,8,0,0">
                            <Border Background="#FFF8FA" CornerRadius="6" Padding="12" Margin="0,0,8,8" Width="160">
                                <StackPanel>
                                    <TextBlock Text="Users" FontWeight="Bold" />
                                    <TextBlock Text="1,234" FontSize="18" FontWeight="Bold" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FFF8FA" CornerRadius="6" Padding="12" Margin="0,0,8,8" Width="160">
                                <StackPanel>
                                    <TextBlock Text="Daily Active" FontWeight="Bold" />
                                    <TextBlock Text="321" FontSize="18" FontWeight="Bold" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="Traffic Trend (placeholder)" Margin="0,8,0,6" />
                        <Border Height="120" Background="#F3F7FF" CornerRadius="4" BorderBrush="#E0E7FF" BorderThickness="1">
                            <Grid>
                                <TextBlock Text="Chart placeholder" Foreground="#9AA6BF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 右侧：最近活动列表 -->
                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Recent Activity" FontSize="16" FontWeight="Bold" />
                        <ListView Margin="0,8,0,0" Height="220">
                            <ListViewItem>
                                <StackPanel>
                                    <TextBlock Text="2026-02-25  User A submitted a task" TextWrapping="Wrap"/>
                                </StackPanel>
                            </ListViewItem>
                            <ListViewItem>
                                <StackPanel>
                                    <TextBlock Text="2026-02-24  System completed data sync" TextWrapping="Wrap"/>
                                </StackPanel>
                            </ListViewItem>
                            <ListViewItem>
                                <StackPanel>
                                    <TextBlock Text="2026-02-23  User B updated settings" TextWrapping="Wrap"/>
                                </StackPanel>
                            </ListViewItem>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 下面可加入更多卡片 -->
            <WrapPanel>
                <Border Background="White" CornerRadius="8" Padding="12" Margin="8" Width="320" Height="140">
                    <StackPanel>
                        <TextBlock Text="Reports" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="Generate daily reports and export data." Margin="0,6,0,0" />
                        <Button Content="生成" Width="80" Margin="0,10,0,0" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" Padding="12" Margin="8" Width="320" Height="140">
                    <StackPanel>
                        <TextBlock Text="Task Queue" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="View and manage background tasks." Margin="0,6,0,0" />
                        <Button Content="查看" Width="80" Margin="0,10,0,0" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</Page>