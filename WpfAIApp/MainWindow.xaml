<Window x:Class="WPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="WPF App" Height="450" Width="800">
    <Grid>
        <!-- 左侧菜单栏 -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" /> <!-- 菜单栏 -->
            <ColumnDefinition Width="*" />   <!-- 内容展示 -->
        </Grid.ColumnDefinitions>

        <!-- 菜单栏 -->
        <Grid Grid.Column="0" Background="#EDEDED">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Button Margin="10" Padding="10" Content="菜单1" Click="Menu1_Click" />
                    <Button Margin="10" Padding="10" Content="菜单2" Click="Menu2_Click" />
                    <Button Margin="10" Padding="10" Content="菜单3" Click="Menu3_Click" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 内容展示区域 -->
        <Grid Grid.Column="1" Background="White">
            <Frame x:Name="contentFrame" NavigationUIVisibility="Hidden" Margin="10" />
        </Grid>

        <!-- 右上角登录/注册按钮 -->
        <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="登录" Grid.Column="0" Margin="5" Click="Login_Click" />
            <Button Content="注册" Grid.Column="1" Margin="5" Click="Register_Click" />
        </Grid>
    </Grid>
</Window>
